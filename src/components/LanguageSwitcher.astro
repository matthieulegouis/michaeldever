---
import { locales, localeNames, localizedPath, type Locale } from "../i18n";

interface Props {
  current: Locale;
}

const { current } = Astro.props;
---

<nav aria-label="Language" class="flex items-center gap-2 text-sm">
  {
    locales.map((loc, i) => (
      <>
        {i > 0 && <span class="text-rule">·</span>}
        <a
          href={localizedPath(loc)}
          hreflang={loc}
          aria-current={loc === current ? "true" : undefined}
          class:list={[
            "tracking-[0.15em] uppercase transition-colors",
            loc === current
              ? "text-accent font-medium"
              : "text-muted hover:text-ink",
          ]}
        >
          {localeNames[loc]}
        </a>
      </>
    ))
  }
</nav>
