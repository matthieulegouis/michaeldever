---
import { t, type Locale } from "../i18n";
import { SITE, PHONES } from "../site";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<header
  class="sticky top-0 z-50 border-b border-rule/70 bg-canvas/80 backdrop-blur-md"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 md:px-10"
  >
    <a
      href="#top"
      class="font-serif text-base tracking-tight text-ink transition-colors hover:text-accent md:text-lg"
    >
      Michael Dever <span class="text-muted">&amp; Associates</span>
    </a>
    <LanguageSwitcher current={locale} />
  </div>
</header>

<main id="top">
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div
      class="mx-auto max-w-6xl px-6 pt-20 pb-24 md:px-10 md:pt-32 md:pb-40"
    >
      <p
        class="reveal text-xs font-medium tracking-[0.25em] uppercase text-accent"
      >
        <span
          class="mr-4 inline-block h-px w-10 translate-y-[-3px] bg-accent align-middle"
        ></span>
        {dict.hero.tagline}
      </p>
      <h1
        class="reveal mt-8 max-w-5xl font-serif text-[2.6rem] leading-[1.06] font-medium tracking-[-0.015em] text-ink md:mt-10 md:text-7xl md:leading-[1.02]"
      >
        {dict.hero.headline}
      </h1>
      <div class="reveal mt-12 max-w-2xl space-y-6 md:mt-14">
        <p class="text-xl leading-relaxed text-ink md:text-2xl">
          {dict.hero.intro1}
        </p>
        <p class="text-base leading-relaxed text-ink-soft md:text-lg">
          {dict.hero.intro2}
        </p>
        <p class="text-base leading-relaxed text-ink-soft md:text-lg">
          {dict.hero.intro3}
        </p>
      </div>
    </div>
  </section>

  <!-- 01 — WHAT WE DO -->
  <section id="work" class="border-t border-rule">
    <div class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-28">
      <div class="grid gap-10 md:grid-cols-12 md:gap-12">
        <div class="md:col-span-4 lg:col-span-3">
          <div class="reveal md:sticky md:top-28">
            <span class="font-serif text-sm text-accent">01</span>
            <h2 class="mt-2 font-serif text-2xl text-ink md:text-[1.75rem]">
              {dict.work.heading}
            </h2>
          </div>
        </div>
        <div
          class="reveal max-w-2xl space-y-6 text-base leading-relaxed text-ink-soft md:col-span-8 md:text-lg lg:col-start-5 lg:col-span-7"
        >
          <p>{dict.work.p1}</p>
          <p>{dict.work.p2}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 02 — AI & CONFIDENTIALITY (feature panel) -->
  <section id="ai" class="bg-ink text-paper">
    <div class="mx-auto max-w-6xl px-6 py-24 md:px-10 md:py-32">
      <div class="grid gap-10 md:grid-cols-12 md:gap-12">
        <div class="md:col-span-4 lg:col-span-3">
          <div class="reveal md:sticky md:top-28">
            <span class="font-serif text-sm text-accent">02</span>
            <h2 class="mt-2 font-serif text-2xl text-paper md:text-[1.75rem]">
              {dict.ai.heading}
            </h2>
          </div>
        </div>
        <div
          class="max-w-2xl md:col-span-8 lg:col-start-5 lg:col-span-7"
        >
          <p
            class="reveal text-base leading-relaxed text-paper/70 md:text-lg"
          >
            {dict.ai.p1}
          </p>
          <div
            class="reveal mt-8 space-y-6 text-base leading-relaxed text-paper/70 md:text-lg"
          >
            <p>{dict.ai.p2}</p>
            <p>{dict.ai.p3}</p>
            <p>{dict.ai.p4}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 03 — CLIENTS -->
  <section id="clients" class="border-t border-rule">
    <div class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-28">
      <div class="grid gap-10 md:grid-cols-12 md:gap-12">
        <div class="md:col-span-4 lg:col-span-3">
          <div class="reveal md:sticky md:top-28">
            <span class="font-serif text-sm text-accent">03</span>
            <h2 class="mt-2 font-serif text-2xl text-ink md:text-[1.75rem]">
              {dict.clients.heading}
            </h2>
          </div>
        </div>
        <p
          class="reveal max-w-2xl text-base leading-relaxed text-ink-soft md:col-span-8 md:text-lg lg:col-start-5 lg:col-span-7"
        >
          {dict.clients.p1}
        </p>
      </div>
    </div>
  </section>

  <!-- 04 — ABOUT -->
  <section id="about" class="border-t border-rule">
    <div class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-28">
      <div class="grid gap-10 md:grid-cols-12 md:gap-12">
        <div class="md:col-span-4 lg:col-span-3">
          <div class="reveal md:sticky md:top-28">
            <span class="font-serif text-sm text-accent">04</span>
            <h2 class="mt-2 font-serif text-2xl text-ink md:text-[1.75rem]">
              {dict.about.heading}
            </h2>
          </div>
        </div>
        <div
          class="max-w-2xl md:col-span-8 lg:col-start-5 lg:col-span-7"
        >
          <p
            class="reveal text-base leading-relaxed text-ink-soft md:text-lg"
          >
            {dict.about.p1}
          </p>
          <p
            class="reveal mt-6 text-base leading-relaxed text-ink-soft md:text-lg"
          >
            {dict.about.p2}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="bg-ink text-paper">
    <div class="mx-auto max-w-6xl px-6 py-24 md:px-10 md:py-32">
      <div class="grid gap-12 md:grid-cols-12 md:gap-12">
        <div class="md:col-span-4 lg:col-span-3">
          <div class="reveal">
            <span class="font-serif text-sm text-accent">—</span>
            <h2 class="mt-2 font-serif text-2xl text-paper md:text-[1.75rem]">
              {dict.contact.heading}
            </h2>
          </div>
        </div>
        <div class="md:col-span-8 lg:col-start-5 lg:col-span-7">
          <a
            href={`mailto:${SITE.email}`}
            class="reveal block font-serif text-2xl tracking-tight break-words text-paper transition-colors hover:text-accent sm:text-4xl md:text-5xl"
          >
            {SITE.email}
          </a>
          <div
            class="reveal mt-12 grid gap-x-10 gap-y-8 border-t border-paper/15 pt-10 sm:grid-cols-2"
          >
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-paper/40">
                {dict.contact.geneva}
              </p>
              <a
                href={PHONES.geneva.href}
                class="mt-1 inline-block font-serif text-lg text-paper transition-colors hover:text-accent md:text-xl"
                >{PHONES.geneva.display}</a
              >
            </div>
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-paper/40">
                {dict.contact.charmey}
              </p>
              <a
                href={PHONES.charmey.href}
                class="mt-1 inline-block font-serif text-lg text-paper transition-colors hover:text-accent md:text-xl"
                >{PHONES.charmey.display}</a
              >
            </div>
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-paper/40">
                {dict.contact.mobile}
              </p>
              <a
                href={PHONES.mobile.href}
                class="mt-1 inline-block font-serif text-lg text-paper transition-colors hover:text-accent md:text-xl"
                >{PHONES.mobile.display}</a
              >
            </div>
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-paper/40">
                {dict.contact.linkedin}
              </p>
              <a
                href={SITE.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1 inline-block font-serif text-lg text-paper underline-offset-4 transition-colors hover:text-accent hover:underline md:text-xl"
                >{dict.contact.linkedinLabel}</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<footer class="bg-ink text-paper/50">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-3 border-t border-paper/15 px-6 py-8 text-xs md:flex-row md:items-center md:justify-between md:px-10"
  >
    <p class="font-serif text-sm text-paper/70">
      Michael Dever &amp; Associates
    </p>
    <div class="flex flex-col gap-1 md:flex-row md:items-center md:gap-6">
      <p>{dict.footer.copyright}</p>
      <p>Geneva · Charmey</p>
    </div>
  </div>
</footer>

<script>
  const els = document.querySelectorAll(".reveal");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if ("IntersectionObserver" in window && !reduce) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
    );
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => el.classList.add("is-visible"));
  }
</script>
