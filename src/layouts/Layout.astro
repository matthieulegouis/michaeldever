---
import "../styles/global.css";
import { t, locales, localizedPath, ogLocales, type Locale } from "../i18n";
import { SITE, OFFICES, PHONES, KNOWS_LANGUAGE } from "../site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

const canonical = new URL(localizedPath(locale), Astro.site).toString();
const ogImage = new URL("/og.png", Astro.site).toString();
const e164 = (p: { href: string }) => p.href.replace("tel:", "");

// ---------------------------------------------------------------------------
// Structured data (Schema.org / JSON-LD) — describes the business as a local
// professional service so search and generative engines can cite it reliably.
// ---------------------------------------------------------------------------
const orgId = `${SITE.url}/#organisation`;
const personId = `${SITE.url}/#michael-dever`;
const websiteId = `${SITE.url}/#website`;

const postalAddresses = OFFICES.map((o) => ({
  "@type": "PostalAddress",
  addressLocality: o.locality,
  addressRegion: o.region,
  addressCountry: "CH",
}));

const places = OFFICES.map((o) => ({
  "@type": "Place",
  name: o.locality,
  address: {
    "@type": "PostalAddress",
    addressLocality: o.locality,
    addressRegion: o.region,
    addressCountry: "CH",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: o.geo.lat,
    longitude: o.geo.lng,
  },
}));

const contactPoints = [
  {
    "@type": "ContactPoint",
    telephone: e164(PHONES.geneva),
    contactType: "office",
    areaServed: "CH",
    availableLanguage: ["en", "fr", "de"],
  },
  {
    "@type": "ContactPoint",
    telephone: e164(PHONES.charmey),
    contactType: "office",
    areaServed: "CH",
    availableLanguage: ["en", "fr", "de"],
  },
  {
    "@type": "ContactPoint",
    telephone: e164(PHONES.mobile),
    contactType: "sales",
    email: SITE.email,
    areaServed: "CH",
    availableLanguage: ["en", "fr", "de"],
  },
];

const services = [
  "English-language translation",
  "Content writing",
  "Editing and revision",
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["ProfessionalService", "Organization"],
      "@id": orgId,
      name: SITE.name,
      url: `${SITE.url}/`,
      description: dict.meta.description,
      email: SITE.email,
      telephone: e164(PHONES.geneva),
      foundingDate: SITE.foundingDate,
      image: ogImage,
      logo: { "@type": "ImageObject", url: ogImage },
      founder: { "@id": personId },
      sameAs: [SITE.linkedin],
      address: postalAddresses,
      location: places,
      contactPoint: contactPoints,
      areaServed: { "@type": "Country", name: "Switzerland" },
      knowsLanguage: [...KNOWS_LANGUAGE],
      knowsAbout: [
        "Financial translation",
        "Investor relations",
        "Corporate communications",
        "Annual and interim reports",
        "Sustainability reporting",
        "Earnings releases",
      ],
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Language services",
        itemListElement: services.map((s) => ({
          "@type": "Offer",
          itemOffered: { "@type": "Service", name: s },
        })),
      },
    },
    {
      "@type": "Person",
      "@id": personId,
      name: SITE.founder,
      jobTitle: "Founder",
      worksFor: { "@id": orgId },
      sameAs: [SITE.linkedin],
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: `${SITE.url}/`,
      name: SITE.name,
      publisher: { "@id": orgId },
      inLanguage: [...locales],
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: dict.meta.title,
      description: dict.meta.description,
      isPartOf: { "@id": websiteId },
      about: { "@id": orgId },
      inLanguage: locale,
    },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>

    <title>{dict.meta.title}</title>
    <meta name="description" content={dict.meta.description} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="author" content={SITE.name} />
    <meta name="theme-color" content="#10192a" />
    <link rel="canonical" href={canonical} />

    <!-- Hreflang alternates -->
    {
      locales.map((loc) => (
        <link
          rel="alternate"
          hreflang={loc}
          href={new URL(localizedPath(loc), Astro.site).toString()}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL("/", Astro.site).toString()}
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={dict.meta.title} />
    <meta property="og:description" content={dict.meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocales[locale]} />
    {
      locales
        .filter((loc) => loc !== locale)
        .map((loc) => (
          <meta property="og:locale:alternate" content={ogLocales[loc]} />
        ))
    }
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={dict.meta.title} />
    <meta name="twitter:description" content={dict.meta.description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Geographic targeting (primary office) -->
    <meta name="geo.region" content="CH-GE" />
    <meta name="geo.placename" content="Geneva" />
    <meta name="geo.position" content="46.2044;6.1432" />
    <meta name="ICBM" content="46.2044, 6.1432" />

    <!-- Icons & manifest -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&display=swap"
    />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
